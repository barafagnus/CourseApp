<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">

    <androidx.cardview.widget.CardView
        android:layout_marginLeft="24dp"
        android:id="@+id/cardview"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:layout_constraintBottom_toBottomOf="parent"
        app:layout_constraintEnd_toEndOf="parent"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent"
        app:cardCornerRadius="24dp">

        <LinearLayout
            android:id="@+id/courseBg"
            android:layout_width="match_parent"
            android:layout_height="300dp"
            android:background="@color/blue"
            android:orientation="vertical">

            <ImageView
                android:id="@+id/courseImage"
                android:layout_width="220dp"
                android:layout_height="200dp"
                android:contentDescription="@string/app_name"
                app:srcCompat="@drawable/course_it_1"
                tools:layout_editor_absoluteX="72dp"
                tools:layout_editor_absoluteY="77dp" />
            <TextView
                android:id="@+id/courseName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="12dp"
                android:textColor="@color/white"
                android:fontFamily="@font/montserrat_alternates_bold"
                android:text="@string/txt_course_java"
                android:textSize="14dp">
            </TextView>
            <TextView
                android:id="@+id/courseInfo"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="6dp"
                android:layout_marginLeft="12dp"
                android:layout_marginRight="12dp"
                android:textColor="@color/white"
                android:fontFamily="@font/montserrat_alternates"
                android:text="@string/txt_course_java_info"
                android:textSize="12dp">
            </TextView>
            <LinearLayout
                android:id="@+id/cardinfobg"
                android:layout_width="match_parent"
                android:layout_height="50dp"
                android:layout_marginTop="6dp"
                android:orientation="horizontal">
                <ImageView
                    android:id="@+id/imageView5"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginLeft="12dp"
                    app:srcCompat="@drawable/ic_ico_countcourses">
                </ImageView>
                <TextView
                    android:id="@+id/countCourses"
                    android:layout_width="70dp"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_countcourses"
                    android:layout_marginTop="12dp"
                    android:layout_marginLeft="5dp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/montserrat_alternates"
                    android:textSize="12dp">
                </TextView>
                <ImageView
                    android:id="@+id/imageView6"
                    android:layout_width="20dp"
                    android:layout_height="20dp"
                    android:layout_marginTop="10dp"
                    android:layout_marginLeft="26dp"
                    app:srcCompat="@drawable/ic_ico_timecourses">
                </ImageView>
                <TextView
                    android:id="@+id/timeCourses"
                    android:layout_width="50dp"
                    android:layout_height="wrap_content"
                    android:text="@string/txt_timecourses"
                    android:layout_marginTop="12dp"
                    android:layout_marginLeft="5dp"
                    android:textColor="@color/white"
                    android:fontFamily="@font/montserrat_alternates"
                    android:textSize="12dp">
                </TextView>
            </LinearLayout>

        </LinearLayout>
    </androidx.cardview.widget.CardView>
</androidx.constraintlayout.widget.ConstraintLayout>